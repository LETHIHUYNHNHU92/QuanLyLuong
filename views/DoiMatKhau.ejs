<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đổi Mật Khẩu - Hệ Thống Lương</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #f4f7f6;
        }
        .form-card {
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 450px;
        }
        h2 { margin: 0 0 5px 0; color: #1c2d33; font-size: 22px; }
        p { color: #5d6d7e; font-size: 14px; margin-bottom: 25px; }
        
        .form-group { margin-bottom: 20px; }
        label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 8px; color: #1c2d33; }
        input { 
            width: 100%; padding: 12px; border: 1px solid #d1d9d6; border-radius: 6px; 
            font-family: 'Inter', sans-serif; font-size: 14px; box-sizing: border-box; transition: 0.3s;
        }
        input:focus { outline: none; border-color: #007355; box-shadow: 0 0 0 3px rgba(0, 115, 85, 0.1); }
        
        .btn-submit {
            width: 100%; background-color: #007355; color: white; padding: 14px; 
            border: none; border-radius: 6px; font-size: 16px; font-weight: 600; cursor: pointer; transition: 0.3s;
            margin-top: 10px;
        }
        .btn-submit:hover { background-color: #005a42; }
        
        .btn-back {
            display: block; text-align: center; margin-top: 20px; color: #5d6d7e; text-decoration: none; font-size: 14px; font-weight: 500;
        }
        .btn-back:hover { color: #007355; text-decoration: underline; }

        .error-msg {
            background-color: #fee2e2; color: #b91c1c; padding: 12px; border-radius: 6px;
            font-size: 13px; text-align: center; margin-bottom: 20px; border: 1px solid #f87171; font-weight: 500;
        }
        .user-badge {
            display: inline-block; background-color: #e5e7eb; padding: 5px 10px; border-radius: 4px; font-size: 12px; color: #374151; font-weight: 600; margin-bottom: 15px;
        }
    </style>
</head>
<body>

    <div class="form-card">
        <span class="user-badge"><i class="fa-solid fa-user"></i> <%= user.HoVaTen %> (<%= user.MaCanBo %>)</span>
        <h2>Đổi Mật Khẩu</h2>
        <p>Bảo mật tài khoản của bạn bằng mật khẩu an toàn</p>

        <% if (typeof error !== 'undefined') { %>
            <div class="error-msg"><i class="fa-solid fa-circle-exclamation"></i> <%= error %></div>
        <% } %>

        <form action="/DoiMatKhau" method="POST">
            <div class="form-group">
                <label>Mật khẩu hiện tại</label>
                <input type="password" name="MatKhauCu" placeholder="Nhập mật khẩu đang dùng..." required>
            </div>
            <div class="form-group">
                <label>Mật khẩu mới</label>
                <input type="password" name="MatKhauMoi" placeholder="Tạo mật khẩu mới..." required>
            </div>
            <div class="form-group">
                <label>Xác nhận mật khẩu mới</label>
                <input type="password" name="XacNhanMatKhau" placeholder="Nhập lại mật khẩu mới..." required>
            </div>
            
            <button type="submit" class="btn-submit"><i class="fa-solid fa-floppy-disk"></i> LƯU MẬT KHẨU</button>
            
            <a href="<%= user.VaiTro === 'Kế toán' ? '/bangluong' : '/me/phieuluong' %>" class="btn-back">
                <i class="fa-solid fa-arrow-left"></i> Quay lại trang chủ
            </a>
        </form>
    </div>

</body>
</html>