<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Phiếu Lương Cá Nhân - Hệ Thống Lương</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root { --primary-green: #007355; --bg-light: #f4f7f6; --text-main: #1c2d33; --border-color: #e8edeb; }
        body { font-family: 'Inter', sans-serif; margin: 0; background-color: var(--bg-light); color: var(--text-main); }
        
        /* Sidebar mini cho nhân viên */
        .sidebar { width: 240px; background-color: var(--primary-green); color: white; padding: 20px 0; position: fixed; height: 100%; }
        .menu-item { padding: 12px 20px; display: block; color: #e5e7eb; text-decoration: none; font-weight: 500; transition: 0.3s; }
        .menu-item:hover, .menu-item.active { background-color: #005a42; color: white; border-left: 4px solid #bbf7d0; }
        
        .main-content { margin-left: 240px; padding: 40px; }
        
        /* Thiết kế Phiếu Lương */
        .payslip-card { background: white; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); max-width: 800px; margin: 0 auto; overflow: hidden; border: 1px solid var(--border-color); }
        .payslip-header { background: var(--primary-green); color: white; padding: 30px; text-align: center; }
        .payslip-body { padding: 40px; }
        
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; padding-bottom: 20px; border-bottom: 2px dashed #eee; }
        .info-item label { font-size: 12px; color: #64748b; text-transform: uppercase; font-weight: 700; display: block; margin-bottom: 5px; }
        .info-item span { font-size: 16px; font-weight: 600; }

        .salary-section { margin-bottom: 25px; }
        .salary-section h3 { font-size: 14px; color: var(--primary-green); border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 15px; }
        
        .salary-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 15px; }
        .salary-row.total { margin-top: 20px; padding: 20px; background: #f0fdf4; border-radius: 8px; font-weight: 700; font-size: 20px; color: var(--primary-green); }
        
        .text-red { color: #e74c3c; }
        .text-green { color: #059669; }

        .btn-print { background: white; border: 1px solid #ddd; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; margin-top: 20px; transition: 0.3s; }
        .btn-print:hover { background: #f8fafc; }
		
		/*  CHỈNH SỬA CHO MÁY IN */
@media print {
    /* 1. Giấu thanh Sidebar và nút In đi để tờ giấy sạch sẽ */
    .sidebar, .btn-print, form, .main-content h1 {
        display: none !important;
    }

    /* 2. Đẩy phần nội dung chính ra giữa tờ giấy */
    .main-content {
        margin-left: 0 !important;
        padding: 0 !important;
    }

    /* 3. Làm cho khung phiếu lương chiếm hết chiều ngang trang giấy */
    .payslip-card {
        box-shadow: none !important;
        border: 1px solid #ccc !important;
        max-width: 100% !important;
    }
}
    </style>
</head>
<body>

    <div class="sidebar">
        <div style="padding: 0 20px; margin-bottom: 30px; color: white;">
            <h2 style="margin: 0; font-size: 18px;">Hệ Thống Lương</h2>
            <span style="font-size: 12px; opacity: 0.8;">Cổng Thông Tin Nhân Viên</span>
        </div>
        <a href="/me/phieuluong" class="menu-item active"><i class="fa-solid fa-file-invoice-dollar"></i> Phiếu Lương</a>
        <a href="/DoiMatKhau" class="menu-item"><i class="fa-solid fa-key"></i> Đổi Mật Khẩu</a>
        <a href="/logout" class="menu-item" style="color: #fda4af;"><i class="fa-solid fa-right-from-bracket"></i> Đăng Xuất</a>
    </div>

    <div class="main-content">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h1>Chào <%= user.HoVaTen %> 👋</h1>
            <form action="/me/phieuluong" method="GET" style="display: flex; gap: 10px;">
                <select name="thang" style="padding: 8px; border-radius: 6px; border: 1px solid #ddd;">
                    <% for(let i=1; i<=12; i++) { %>
                        <option value="<%= i %>" <%= thang == i ? 'selected' : '' %>>Tháng <%= i %></option>
                    <% } %>
                </select>
                <button type="submit" style="background: var(--primary-green); color: white; border: none; padding: 8px 15px; border-radius: 6px; cursor: pointer;">Xem</button>
            </form>
        </div>

        <% if (!phieu) { %>
            <div style="text-align: center; padding: 100px; background: white; border-radius: 12px; border: 1px solid #eee;">
                <i class="fa-solid fa-face-clock" style="font-size: 50px; color: #cbd5e1; margin-bottom: 20px; display: block;"></i>
                <p style="color: #64748b;">Phiếu lương tháng <%= thang %>/<%= nam %> chưa được kế toán chốt. Vui lòng quay lại sau!</p>
            </div>
        <% } else { %>
            <div class="payslip-card">
                <div class="payslip-header">
                    <h2 style="margin: 0;">PHIẾU LƯƠNG CHI TIẾT</h2>
                    <p style="margin: 5px 0 0; opacity: 0.9;">Tháng <%= thang %> Năm <%= nam %></p>
                </div>
                
                <div class="payslip-body">
                    <div class="info-grid">
                        <div class="info-item">
                            <label>Họ và Tên</label>
                            <span><%= user.HoVaTen %></span>
                        </div>
                        <div class="info-item">
                            <label>Mã Nhân Viên</label>
                            <span><%= user.MaCanBo %></span>
                        </div>
                    </div>

                    <div class="salary-section">
                        <h3>THU NHẬP</h3>
                        <div class="salary-row">
                            <span>Lương cơ bản</span>
                            <span><%= new Intl.NumberFormat('vi-VN').format(phieu.LuongCoBan) %>đ</span>
                        </div>
                        <div class="salary-row">
                            <span>Ngày công thực tế</span>
                            <span><%= phieu.SoNgayLam %> ngày</span>
                        </div>
                        <div class="salary-row text-green">
                            <span>Phụ cấp & Thưởng</span>
                            <span>+ <%= new Intl.NumberFormat('vi-VN').format((phieu.TongPhuCap || 0) + (phieu.Thuong || 0)) %>đ</span>
                        </div>
                    </div>

                    <div class="salary-section">
                        <h3>CÁC KHOẢN GIẢM TRỪ</h3>
                        <div class="salary-row text-red">
                            <span>Bảo hiểm xã hội (10.5%)</span>
                            <span>- <%= new Intl.NumberFormat('vi-VN').format(phieu.BaoHiem || 0) %>đ</span>
                        </div>
                        <div class="salary-row text-red">
                            <span>Thuế TNCN</span>
                            <span>- <%= new Intl.NumberFormat('vi-VN').format(phieu.ThueTNCN || 0) %>đ</span>
                        </div>
                        <div class="salary-row text-red">
                            <span>Phạt & Tạm ứng</span>
                            <span>- <%= new Intl.NumberFormat('vi-VN').format((phieu.Phat || 0) + (phieu.TamUng || 0)) %>đ</span>
                        </div>
                    </div>

                    <div class="salary-row total">
                        <span>THỰC LÃNH</span>
                        <span><%= new Intl.NumberFormat('vi-VN').format(phieu.ThucLanh) %>đ</span>
                    </div>

                    <div style="text-align: center; margin-top: 30px;">
                        <button class="btn-print" onclick="window.print()"><i class="fa-solid fa-print"></i> In Phiếu Lương</button>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

</body>
</html>